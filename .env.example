# Copy this file to ".env" and fill in whichever backend you want to use.
# All of these are OPTIONAL. If none are set, the pipeline falls back to a
# deterministic extractive generator so the demo still runs end-to-end.
# Backends are probed in the order below; the first one configured wins.

# --- Groq (recommended: free, fast, hosted, no local install) -----------
# Get a free key at https://console.groq.com/keys
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile

# --- OpenAI -------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# --- Anthropic ----------------------------------------------------------
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Ollama (local) -----------------------------------------------------
# Start Ollama with: `ollama serve` and `ollama pull llama3`
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# --- Pipeline tuning ----------------------------------------------------
# TOP_K=5            # how many chunks to retrieve before RBAC filtering
# CHUNK_SIZE=600     # characters per chunk
# CHUNK_OVERLAP=80   # character overlap between chunks
